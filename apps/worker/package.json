{
  "name": "@smash/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "lint": "eslint src --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rimraf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@smash/shared-types": "workspace:*",
    "@smash/shared-utils": "workspace:*",
    "@prisma/client": "^5.20.0",
    "bullmq": "^5.21.2",
    "dotenv": "^16.4.5",
    "ioredis": "^5.4.1",
    "pino": "^9.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.16.10",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.2"
  }
}
