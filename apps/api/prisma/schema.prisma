// ═══════════════════════════════════════════════════════════════════════════
//  Smash — Schema Prisma
//  Sistema POS multi-sucursal para cadena de comida rápida en Paraguay.
//
//  Convenciones:
//   - Modelos: PascalCase español (dominio).
//   - Tablas:  snake_case español (vía @@map).
//   - IDs:     cuid() por default.
//   - Dinero:  BigInt en guaraníes (entero, sin decimales).
//   - Stock:   Decimal(15,3) — soporta gramos/mililitros.
//   - Soft delete: campo `deletedAt` en entidades históricas.
//   - Multi-tenant: empresa_id en toda entidad de negocio + middleware tenant.
//
//  Campos preparados para SIFEN (Fase 4) — quedan nulos hasta integración:
//   cdc, xml_firmado, estado_sifen, fecha_envio_sifen, fecha_aprobacion_sifen.
// ═══════════════════════════════════════════════════════════════════════════

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions", "fullTextSearchPostgres"]
  binaryTargets   = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider   = "postgresql"
  extensions = [pgcrypto, pgTrgm(map: "pg_trgm"), unaccent, uuidOssp(map: "uuid-ossp")]
}

