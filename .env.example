# ==============================================
# Smash — variables de entorno
# Copiar a .env y ajustar valores antes de levantar el stack.
# ==============================================

# ----- Database -----
# En dev: Postgres local nativo. La BD `smash` debe existir previamente.
# Si preferís contenedor: pnpm services:up:db (levanta Postgres en docker compose).
DB_HOST=localhost
DB_USER=postgres
DB_PASSWORD=12345
DB_NAME=smash

# DATABASE_URL es derivado de las variables DB_* arriba — Prisma CLI lo necesita.
# Mantener sincronizado si cambiás cualquiera de las DB_*.
DATABASE_URL=postgresql://postgres:12345@localhost:5432/smash?schema=public

# ----- API -----
PORT=3001
NODE_ENV=development
# CORS — lista separada por comas, o `*` para reflejar el Origin (sólo dev).
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3002,http://localhost:3003

# ----- JWT -----
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_to_a_long_random_string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ----- Bcrypt -----
BCRYPT_ROUNDS=12

# ----- Redis -----
REDIS_URL=redis://localhost:6379

# ----- Frontend (Next.js apps) -----
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# ----- pgAdmin (sólo si levantás docker compose --profile tools) -----
PGADMIN_EMAIL=admin@smash.local
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050

# ----- SIFEN (placeholder, Fase 4) -----
